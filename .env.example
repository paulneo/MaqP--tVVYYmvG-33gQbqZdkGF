# Copia este archivo a .env y completá los valores.
# .env está en .gitignore — nunca lo commitees.

# ── Anthropic (scripts ai:outline, ai:draft, ai:meta) ─────────────────
# Sacala desde https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Modelo por defecto para los scripts de IA.
# Opciones actuales: claude-sonnet-4-6, claude-opus-4-8, claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Cloudinary (scripts migrate-images*, nueva subida de fotos vía CMS) ─
# Cloud name es publico (aparece en las URLs)
CLOUDINARY_CLOUD_NAME=vadks4nc
# API key es publico
CLOUDINARY_API_KEY=411149126798244
# ⚠ API SECRET es sensible - NO COMMITEAR
CLOUDINARY_API_SECRET=

# ── Netlify (opcional, para trigger de rebuild programado) ────────────
# Este webhook lo usa .github/workflows/scheduled-rebuild.yml para
# publicar posts programados. Sacar de Netlify -> Site settings -> Build hooks
NETLIFY_BUILD_HOOK=

# ── Vercel (opcional, si algun dia migras) ────────────────────────────
VERCEL_DEPLOY_HOOK=
