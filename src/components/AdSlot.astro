---
/**
 * Componente de anuncio AdSense con variantes pre-dimensionadas.
 *
 * En PROD con `adsenseId` configurado: renderiza la etiqueta <ins>
 * de Google AdSense + el push para inicializar.
 * En DEV o sin adsenseId: caja punteada visible con label, para que
 * se vea dónde van los anuncios sin layout shift al activar AdSense.
 *
 * Variantes:
 *   - banner-top:     728×90 desktop / 320×100 mobile (responsive)
 *   - in-article:     responsive in-article (mejor CTR mid-content)
 *   - sidebar-sticky: 300×600 (rascacielos, sticky al hacer scroll)
 *   - footer:         728×90 (banner bajo)
 *   - inline:         responsive, nativo
 *
 * Uso:
 *   <AdSlot variant="banner-top" slot="1234567890" />
 *   <AdSlot variant="in-article" slot="9876543210" />
 *
 * Los IDs de slot vienen del panel de AdSense → Anuncios → Por unidad
 * de anuncio. Si dejás slot vacío, se renderiza el placeholder.
 */
import { adsenseId } from '../config'

interface Props {
    variant: 'banner-top' | 'in-article' | 'sidebar-sticky' | 'footer' | 'inline'
    slot?: string
    class?: string
}

const { variant, slot = '', class: className = '' } = Astro.props

const SIZES: Record<Props['variant'], {
    label: string;
    classes: string;
    minH: string;
    format: string;
    layout?: string;
}> = {
    'banner-top': {
        label: 'AD · banner top',
        classes: 'w-full max-w-[728px] mx-auto',
        minH: 'min-h-[90px] md:min-h-[90px]',
        format: 'horizontal',
    },
    'in-article': {
        label: 'AD · in-article',
        classes: 'w-full max-w-[680px] mx-auto',
        minH: 'min-h-[280px]',
        format: 'fluid',
        layout: 'in-article',
    },
    'sidebar-sticky': {
        label: 'AD · sidebar',
        classes: 'w-full max-w-[300px]',
        minH: 'min-h-[600px]',
        format: 'vertical',
    },
    'footer': {
        label: 'AD · footer',
        classes: 'w-full max-w-[728px] mx-auto',
        minH: 'min-h-[90px]',
        format: 'horizontal',
    },
    'inline': {
        label: 'AD · responsive',
        classes: 'w-full',
        minH: 'min-h-[120px]',
        format: 'auto',
    },
}

const cfg = SIZES[variant]
const isProd = import.meta.env.PROD
const adActive = isProd && Boolean(adsenseId) && Boolean(slot)
// En prod con Auto-ads activo (adsenseId cargado, sin slot manual), el
// componente se oculta y deja que Google Auto-ads decida dónde inyectar
// anuncios. En dev seguimos mostrando el placeholder para ver el layout.
const hideForAutoAds = isProd && Boolean(adsenseId) && !slot
---

{!hideForAutoAds && (
<aside
    class:list={[
        'ad-slot relative my-8',
        cfg.classes,
        cfg.minH,
        className,
    ]}
    aria-label="Publicidad"
>
    <div class="text-[0.65rem] uppercase tracking-[0.18em] text-black/40 dark:text-white/40 mb-1.5 text-center">
        Publicidad
    </div>

    {adActive ? (
        <>
            <ins
                class="adsbygoogle block"
                style="display:block"
                data-ad-client={adsenseId}
                data-ad-slot={slot}
                data-ad-format={cfg.format}
                data-ad-layout={cfg.layout}
                data-full-width-responsive="true"
            ></ins>
            <script is:inline>
                (adsbygoogle = window.adsbygoogle || []).push({})
            </script>
        </>
    ) : (
        <!-- Placeholder visible en dev y antes de configurar slot -->
        <div class="absolute inset-0 flex items-center justify-center rounded-lg border-2 border-dashed border-black/15 dark:border-white/15 bg-black/[0.02] dark:bg-white/[0.03] mt-6">
            <div class="text-center px-4">
                <p class="text-[0.7rem] uppercase tracking-[0.2em] font-semibold text-black/40 dark:text-white/40">
                    {cfg.label}
                </p>
                <p class="text-[0.65rem] text-black/30 dark:text-white/30 mt-1">
                    {slot ? `slot ${slot}` : 'sin slot asignado'}
                </p>
            </div>
        </div>
    )}
</aside>
)}
